# LINE Bot 設定
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

# Google Sheets 設定
# GOOGLE_SHEETS_ID：試算表網址中 /d/ 後面那段 ID
GOOGLE_SHEETS_ID=your_google_sheets_id_here
# GOOGLE_SERVICE_ACCOUNT_KEY：從 GCP 下載的 JSON 金鑰，整個貼上（單行）
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\\n...\\n-----END RSA PRIVATE KEY-----\\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# LIFF 設定
LIFF_ID=your_liff_id_here

# 主管 LINE userId（U 開頭的 32 碼，非顯示名稱）
MANAGER_LINE_ID=your_manager_line_user_id_here

# HR LINE userId（U 開頭的 32 碼）
HR_LINE_ID=your_hr_line_user_id_here

# 伺服器設定
PORT=3000
